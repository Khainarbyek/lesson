---
import "../styles/global.css";
import { getBuildVersion } from "../lib/buildVersion";
import type { LocaleCode } from "../lib/locales";
import { defaultLocale } from "../lib/locales";
import {
  defaultSocialImage,
  getCanonicalUrl,
  socialImageHeight,
  socialImageType,
  socialImageWidth,
  type LocaleAlternate
} from "../lib/seo";

type Props = {
  title: string;
  description: string;
  locale: LocaleCode;
  canonicalPath?: string;
  alternateLocales?: LocaleAlternate[];
  socialImage?: string;
};

const {
  title,
  description,
  locale,
  canonicalPath = Astro.url.pathname,
  alternateLocales = [],
  socialImage = defaultSocialImage
} = Astro.props;
const canonicalUrl = getCanonicalUrl(canonicalPath);
const socialImageUrl = getCanonicalUrl(socialImage);
const defaultAlternate = alternateLocales.find((alternate) => alternate.locale === defaultLocale);
const ogLocales: Record<LocaleCode, string> = {
  en: "en_US",
  ru: "ru_RU",
  kk: "kk_KZ"
};
const buildVersion = getBuildVersion();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLocales.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
    {defaultAlternate && <link rel="alternate" hreflang="x-default" href={defaultAlternate.href} />}
    <meta property="og:site_name" content="Uyren" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content={String(socialImageWidth)} />
    <meta property="og:image:height" content={String(socialImageHeight)} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:alt" content="Uyren learning app for children" />
    <meta property="og:locale" content={ogLocales[locale]} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="Uyren learning app for children" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <footer class="build-version" aria-label="Build version">Build {buildVersion}</footer>
  </body>
</html>
