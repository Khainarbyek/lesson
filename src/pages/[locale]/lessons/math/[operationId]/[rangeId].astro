---
import { ChevronLeft } from "lucide-react";
import { ArithmeticActivity } from "../../../../../components/ArithmeticActivity";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import {
  getArithmeticOperationIds,
  getArithmeticPracticeCopy,
  getArithmeticRange,
  getArithmeticRangeIds,
  getHomeCopy,
  getLessonById,
  isArithmeticOperationId
} from "../../../../../lib/content";
import { defaultLocale, isLocaleCode, localeCodes, localizedPath, type LocaleCode } from "../../../../../lib/locales";
import { getLocalizedAlternates } from "../../../../../lib/seo";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) =>
    getArithmeticOperationIds().flatMap((operationId) =>
      getArithmeticRangeIds().map((rangeId) => ({
        params: { locale, operationId, rangeId }
      }))
    )
  );
}

const localeParam = Astro.params.locale;
const locale: LocaleCode = isLocaleCode(localeParam) ? localeParam : defaultLocale;
const operationIdParam = Astro.params.operationId ?? "addition";
const operationId = isArithmeticOperationId(operationIdParam) ? operationIdParam : "addition";
const rangeId = Astro.params.rangeId ?? "0-10";
const range = getArithmeticRange(locale, operationId, rangeId) ?? getArithmeticRange(locale, operationId, "0-10");
const homeCopy = getHomeCopy(locale);
const mathLesson = getLessonById(locale, "math");
const activityCopy = getArithmeticPracticeCopy(locale);
const resolvedRangeId = range?.id ?? "0-10";
const rangePath = `/lessons/math/${operationId}/${resolvedRangeId}`;
---

<BaseLayout
  title={`${range?.title ?? homeCopy.productName} - ${homeCopy.productName}`}
  description={range?.description ?? homeCopy.heroSubtitle}
  locale={locale}
  canonicalPath={localizedPath(locale, rangePath)}
  alternateLocales={getLocalizedAlternates(rangePath)}
>
  <main class="arithmetic-range-page">
    <div class="container-shell lesson-nav">
      <a href={localizedPath(locale, `/lessons/math/${operationId}`)} class="back-link" aria-label={homeCopy.navLessons}>
        <ChevronLeft aria-hidden="true" focusable="false" strokeWidth={2.4} />
      </a>
    </div>

    {range && (
      <ArithmeticActivity
        client:load
        operationId={operationId}
        title={range.title}
        subject={mathLesson?.subject ?? homeCopy.navLessons}
        range={range}
        copy={activityCopy}
      />
    )}
  </main>
</BaseLayout>

<style>
  .arithmetic-range-page {
    min-height: 100vh;
    padding: 12px 0 48px;
  }

  .lesson-nav {
    margin-bottom: 8px;
  }

  .back-link {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: rgba(23, 32, 51, 0.76);
    box-shadow: var(--shadow-card);
  }

  .back-link svg {
    width: 24px;
    height: 24px;
  }
</style>
