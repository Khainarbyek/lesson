---
import { ChevronLeft } from "lucide-react";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  getArithmeticOperationIds,
  getArithmeticRanges,
  getArithmeticTopicCopy,
  getHomeCopy,
  isArithmeticOperationId
} from "../../../../lib/content";
import { defaultLocale, isLocaleCode, localeCodes, localizedPath, type LocaleCode } from "../../../../lib/locales";
import { getLocalizedAlternates } from "../../../../lib/seo";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) =>
    getArithmeticOperationIds().map((operationId) => ({
      params: { locale, operationId }
    }))
  );
}

const localeParam = Astro.params.locale;
const locale: LocaleCode = isLocaleCode(localeParam) ? localeParam : defaultLocale;
const operationIdParam = Astro.params.operationId ?? "addition";
const operationId = isArithmeticOperationId(operationIdParam) ? operationIdParam : "addition";
const homeCopy = getHomeCopy(locale);
const copy = getArithmeticTopicCopy(locale, operationId);
const ranges = getArithmeticRanges(locale, operationId);
const operationPath = `/lessons/math/${operationId}`;
---

<BaseLayout
  title={`${copy.title} - ${homeCopy.productName}`}
  description={copy.lead}
  locale={locale}
  canonicalPath={localizedPath(locale, operationPath)}
  alternateLocales={getLocalizedAlternates(operationPath)}
>
  <main class="arithmetic-page">
    <div class="container-shell lesson-nav">
      <a href={localizedPath(locale, "/lessons/math")} class="back-link" aria-label={homeCopy.navLessons}>
        <ChevronLeft aria-hidden="true" focusable="false" strokeWidth={2.4} />
      </a>
    </div>

    <section class="arithmetic-shell-page container-shell play-card">
      <div class="arithmetic-heading">
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
      </div>

      <div class="range-grid">
        {ranges.map((range) => (
          <a class="range-card play-card" href={range.route}>
            <strong>{range.label}</strong>
            <span>{range.description}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .arithmetic-page {
    min-height: 100vh;
    padding: 12px 0 48px;
  }

  .lesson-nav {
    margin-bottom: 8px;
  }

  .back-link {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: rgba(23, 32, 51, 0.76);
    box-shadow: var(--shadow-card);
  }

  .back-link svg {
    width: 24px;
    height: 24px;
  }

  .arithmetic-shell-page {
    display: grid;
    gap: 18px;
    max-width: 820px;
    padding: clamp(18px, 5vw, 34px);
  }

  .arithmetic-heading {
    display: grid;
    gap: 8px;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 9vw, 4.4rem);
    line-height: 0.98;
  }

  p {
    margin: 0;
    color: rgba(23, 32, 51, 0.68);
    font-size: 1rem;
    line-height: 1.5;
  }

  .range-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .range-card {
    display: grid;
    gap: 8px;
    min-height: 112px;
    align-content: center;
    padding: 14px;
    transition: transform 160ms ease, border-color 160ms ease;
  }

  .range-card:hover {
    border-color: rgba(76, 154, 255, 0.36);
    transform: translateY(-2px);
  }

  .range-card strong {
    color: var(--color-sky);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 9vw, 2.6rem);
    line-height: 1;
  }

  .range-card span {
    color: rgba(23, 32, 51, 0.66);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.34;
  }

  @media (min-width: 640px) {
    .range-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
  }
</style>
