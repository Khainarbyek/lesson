---
import { LessonActivity } from "../../../components/LessonActivity";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getHomeCopy, getLessonById, getLessonIds, getLessons, getMathTopics } from "../../../lib/content";
import { defaultLocale, isLocaleCode, localeCodes, localizedPath, type LocaleCode } from "../../../lib/locales";
import { getLocalizedAlternates } from "../../../lib/seo";
import { ChevronLeft } from "lucide-react";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) =>
    getLessonIds().map((lessonId) => ({
      params: { locale, lessonId }
    }))
  );
}

const localeParam = Astro.params.locale;
const locale: LocaleCode = isLocaleCode(localeParam) ? localeParam : defaultLocale;
const lessonId = Astro.params.lessonId ?? "";
const lesson = getLessonById(locale, lessonId);
const copy = getHomeCopy(locale);
const fallbackLesson = getLessons(locale)[0];
const pageLesson = lesson ?? fallbackLesson;
const title = `${pageLesson.title} - ${copy.productName}`;
const lessonPath = `/lessons/${pageLesson.id}`;
const isMathSubject = pageLesson.id === "math";
const mathTopics = isMathSubject ? getMathTopics(locale) : [];
---

<BaseLayout
  title={title}
  description={pageLesson.description}
  locale={locale}
  canonicalPath={localizedPath(locale, lessonPath)}
  alternateLocales={getLocalizedAlternates(lessonPath)}
>
  <main class="lesson-page">
    <div class="container-shell lesson-nav">
      <a href={localizedPath(locale, "/")} class="back-link" aria-label={copy.navLessons}>
        <ChevronLeft aria-hidden="true" focusable="false" strokeWidth={2.4} />
      </a>
    </div>

    {isMathSubject ? (
      <section class="subject-page container-shell play-card">
        <span class="soon-pill">{pageLesson.ageRange}</span>
        <h1>{pageLesson.title}</h1>
        <p>{pageLesson.description}</p>
        <div class="topic-grid" aria-label={pageLesson.title}>
          {mathTopics.map((topic) => (
            <a class="topic-card play-card" href={topic.route}>
              <span aria-hidden="true">{topic.icon}</span>
              <div>
                <h2>{topic.title}</h2>
                <p>{topic.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : pageLesson.status === "playable" ? (
      <LessonActivity client:load lesson={pageLesson} />
    ) : (
      <section class="coming-soon container-shell play-card">
        <div class="soon-visual">
          <img src={pageLesson.image.src} alt={pageLesson.image.alt} loading="eager" width="320" height="210" />
          <span aria-hidden="true">{pageLesson.icon}</span>
        </div>
        <span class="soon-pill">{copy.soonLabel}</span>
        <h1>{pageLesson.title}</h1>
        <p>{pageLesson.description}</p>
        <p class="soon-note">{pageLesson.soonNote}</p>
        <a class="home-link" href={localizedPath(locale, "/")}>{copy.exploreSoon}</a>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .lesson-page {
    min-height: 100vh;
    padding: 12px 0 48px;
  }

  .lesson-nav {
    margin-bottom: 8px;
  }

  .back-link {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: rgba(23, 32, 51, 0.76);
    box-shadow: var(--shadow-card);
  }

  .back-link svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .coming-soon {
    display: grid;
    justify-items: start;
    gap: 18px;
    max-width: 760px;
    padding: clamp(24px, 5vw, 42px);
  }

  .subject-page {
    display: grid;
    gap: 18px;
    max-width: 860px;
    padding: clamp(20px, 5vw, 38px);
  }

  .topic-grid {
    display: grid;
    gap: 12px;
  }

  .topic-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 14px;
    transition: transform 160ms ease, border-color 160ms ease;
  }

  .topic-card:hover {
    border-color: rgba(76, 154, 255, 0.36);
    transform: translateY(-2px);
  }

  .topic-card > span {
    display: grid;
    width: 58px;
    height: 58px;
    place-items: center;
    border-radius: 8px;
    background: rgba(76, 154, 255, 0.14);
    color: #245985;
    font-family: var(--font-display);
    font-weight: 1000;
  }

  .topic-card h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 6vw, 2rem);
    line-height: 1.05;
  }

  .topic-card p {
    margin-top: 6px;
    font-size: 0.96rem;
    line-height: 1.42;
  }

  .soon-visual {
    position: relative;
    width: min(100%, 360px);
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    box-shadow: inset 0 0 0 2px rgba(23, 32, 51, 0.08);
  }

  .soon-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .soon-visual span {
    position: absolute;
    right: 12px;
    bottom: 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    color: var(--color-ink);
    padding: 7px 10px;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 1000;
  }

  .soon-pill {
    border-radius: 999px;
    background: rgba(76, 154, 255, 0.14);
    color: #245985;
    padding: 8px 12px;
    font-weight: 1000;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 5.2rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  p {
    max-width: 650px;
    margin: 0;
    color: rgba(23, 32, 51, 0.72);
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .soon-note {
    border-left: 6px solid var(--color-sun);
    padding-left: 16px;
    font-weight: 800;
  }

  .home-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    border-radius: 999px;
    background: var(--color-ink);
    color: #fff;
    padding: 0 18px;
    font-weight: 1000;
  }
</style>
