---
import type { HomeCopy, Lesson } from "../lib/content";

type Props = {
  lesson: Lesson;
  copy: HomeCopy;
};

const { lesson, copy } = Astro.props;
const isPlayable = lesson.status === "playable";
const accentClass = `accent-${lesson.accent}`;
---

<article class:list={["lesson-card", "play-card", accentClass]} data-lesson-card data-age={lesson.ageRange}>
  <div class="lesson-visual">
    <img src={lesson.image.src} alt={lesson.image.alt} loading="lazy" width="320" height="210" />
    <span aria-hidden="true">{lesson.icon}</span>
  </div>
  <div class="lesson-body">
    <div class="lesson-meta">
      <span>{lesson.subject}</span>
      <span>{lesson.ageRange}</span>
    </div>
    <h3>{lesson.title}</h3>
    <p>{lesson.description}</p>
  </div>
  <div class="lesson-footer">
    <span class:list={["status-pill", { playable: isPlayable }]}>
      {isPlayable ? copy.playableLabel : copy.soonLabel}
    </span>
    <a class="lesson-link touch-target" href={lesson.route}>
      {isPlayable ? copy.startLesson : copy.exploreSoon}
    </a>
  </div>
</article>

<style>
  .lesson-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    min-height: 180px;
    padding: 14px;
    position: relative;
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .lesson-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-soft), transparent 55%);
    pointer-events: none;
  }

  .lesson-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }

  .accent-berry {
    --accent: var(--color-berry);
    --accent-soft: rgba(217, 72, 125, 0.16);
  }

  .accent-sky {
    --accent: var(--color-sky);
    --accent-soft: rgba(76, 154, 255, 0.16);
  }

  .accent-leaf {
    --accent: var(--color-leaf);
    --accent-soft: rgba(49, 166, 106, 0.16);
  }

  .accent-sun {
    --accent: var(--color-sun);
    --accent-soft: rgba(255, 200, 87, 0.24);
  }

  .lesson-visual,
  .lesson-body,
  .lesson-footer {
    position: relative;
  }

  .lesson-visual {
    position: relative;
    width: 86px;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    box-shadow: inset 0 0 0 2px rgba(23, 32, 51, 0.08);
  }

  .lesson-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lesson-visual span {
    position: absolute;
    right: 6px;
    bottom: 6px;
    max-width: calc(100% - 12px);
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--accent);
    padding: 4px 7px;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 1000;
    line-height: 1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lesson-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .lesson-meta span,
  .status-pill {
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: rgba(23, 32, 51, 0.68);
    padding: 6px 10px;
    font-size: 0.76rem;
    font-weight: 900;
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.24rem, 2.4vw, 1.65rem);
    line-height: 1.08;
  }

  p {
    margin: 10px 0 0;
    color: rgba(23, 32, 51, 0.7);
    line-height: 1.52;
  }

  .lesson-footer {
    display: flex;
    grid-column: 1 / -1;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .status-pill.playable {
    background: rgba(49, 166, 106, 0.14);
    color: #14673d;
  }

  .lesson-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-ink);
    color: #fff;
    padding: 0 16px;
    font-size: 0.88rem;
    font-weight: 900;
  }

  @media (min-width: 700px) {
    .lesson-card {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr auto;
      gap: 18px;
      min-height: 290px;
      padding: 18px;
    }

    .lesson-footer {
      grid-column: auto;
    }

    .lesson-visual {
      width: 100%;
      aspect-ratio: 16 / 10;
    }
  }
</style>
