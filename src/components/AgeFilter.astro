---
import type { AgeRange } from "../lib/content";

type Props = {
  ageRanges: AgeRange[];
};

const { ageRanges } = Astro.props;
---

<div class="age-grid" aria-label="Age ranges" data-age-filter-root>
  {ageRanges.map((range) => (
    <button class="age-card play-card" type="button" data-age-filter={range.id} aria-pressed="false">
      <strong>{range.label}</strong>
      <span>{range.description}</span>
    </button>
  ))}
</div>

<script>
  import { setupAgeFilter } from "../lib/ageFilter";

  setupAgeFilter();
</script>

<style>
  .age-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .age-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    min-height: 84px;
    align-items: center;
    padding: 14px;
    color: inherit;
    cursor: pointer;
    font: inherit;
    text-align: left;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .age-card:hover,
  .age-card.active {
    border-color: rgba(76, 154, 255, 0.36);
    transform: translateY(-2px);
  }

  .age-card.active {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 14px 32px rgba(76, 154, 255, 0.18);
  }

  .age-card:focus-visible {
    outline: 3px solid rgba(76, 154, 255, 0.46);
    outline-offset: 3px;
  }

  .age-card strong {
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1;
  }

  .age-card span {
    color: rgba(23, 32, 51, 0.68);
    font-size: 0.94rem;
    font-weight: 700;
  }

  @media (min-width: 680px) {
    .age-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .age-card {
      grid-template-columns: 1fr;
      min-height: 110px;
      align-content: center;
      text-align: center;
    }

    .age-card strong {
      font-size: clamp(1.45rem, 4vw, 2.2rem);
    }
  }
</style>
