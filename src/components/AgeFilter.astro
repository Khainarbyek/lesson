---
import type { AgeRange } from "../lib/content";

type Props = {
  ageRanges: AgeRange[];
};

const { ageRanges } = Astro.props;
---

<div class="age-grid" aria-label="Age ranges">
  {ageRanges.map((range) => (
    <a class="age-card play-card" href={`#age-${range.id}`} data-age={range.id}>
      <strong>{range.label}</strong>
      <span>{range.description}</span>
    </a>
  ))}
</div>

<style>
  .age-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .age-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    min-height: 84px;
    align-items: center;
    padding: 14px;
    text-align: left;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .age-card:hover {
    border-color: rgba(76, 154, 255, 0.36);
    transform: translateY(-2px);
  }

  .age-card strong {
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1;
  }

  .age-card span {
    color: rgba(23, 32, 51, 0.68);
    font-size: 0.94rem;
    font-weight: 700;
  }

  @media (min-width: 680px) {
    .age-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .age-card {
      grid-template-columns: 1fr;
      min-height: 110px;
      align-content: center;
      text-align: center;
    }

    .age-card strong {
      font-size: clamp(1.45rem, 4vw, 2.2rem);
    }
  }
</style>
